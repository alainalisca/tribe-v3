# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Push Notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:your-email@example.com

# Site URL (used in emails and calendar links)
NEXT_PUBLIC_SITE_URL=https://tribe-v3.vercel.app

# Email
RESEND_API_KEY=re_your-resend-key

# Cron Jobs
CRON_SECRET=generate-a-strong-random-string-here

# Webhooks
WEBHOOK_SECRET=generate-a-strong-random-string-here

# Firebase (for native apps)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Payments - Stripe (USD)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Payments - Wompi (COP)
WOMPI_PRIVATE_KEY=prv_your-wompi-private-key
WOMPI_PUBLIC_KEY=pub_your-wompi-public-key
WOMPI_EVENTS_SECRET=your-wompi-events-webhook-secret
WOMPI_SANDBOX=false

# Google Maps / Places
GOOGLE_MAPS_SERVER_KEY=your-google-maps-server-key
NEXT_PUBLIC_GOOGLE_PLACES_KEY=your-google-places-client-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-client-key

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# SMS Notifications (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
FEEDBACK_SMS_NUMBER=

# External Event APIs (optional - cold-start discovery)
EVENTBRITE_API_KEY=your-eventbrite-api-key

# Error tracking (LR-01 launch readiness — Sentry)
# Browser DSN: visible in the client bundle, used by sentry.client.config.ts
NEXT_PUBLIC_SENTRY_DSN=https://...@oXXXXXX.ingest.sentry.io/XXXXXX
# Server DSN: used by sentry.server.config.ts + sentry.edge.config.ts. Can be
# the same string as NEXT_PUBLIC_SENTRY_DSN — kept separate so a future split
# DSN per runtime is a config change, not a code change.
SENTRY_DSN=https://...@oXXXXXX.ingest.sentry.io/XXXXXX
# Build-time only — used by withSentryConfig to upload source maps. Generate
# at: https://sentry.io/settings/account/api/auth-tokens (scope: project:releases)
SENTRY_AUTH_TOKEN=sntrys_eyJ...
# Sentry organization + project slugs. Defaults match Al's account; override
# only if the Sentry project is renamed.
SENTRY_ORG=tribe
SENTRY_PROJECT=tribe-v3

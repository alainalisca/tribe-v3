# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Push Notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:your-email@example.com

# Site URL (used in emails and calendar links)
NEXT_PUBLIC_SITE_URL=https://tribe-v3.vercel.app

# Email
RESEND_API_KEY=re_your-resend-key

# Cron Jobs
CRON_SECRET=generate-a-strong-random-string-here

# Webhooks
WEBHOOK_SECRET=generate-a-strong-random-string-here

# Firebase (for native apps)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Payments - Stripe (USD)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Payments - Wompi (COP)
WOMPI_PRIVATE_KEY=prv_your-wompi-private-key
WOMPI_PUBLIC_KEY=pub_your-wompi-public-key
WOMPI_EVENTS_SECRET=your-wompi-events-webhook-secret
WOMPI_SANDBOX=false

# Google Maps / Places
GOOGLE_MAPS_SERVER_KEY=your-google-maps-server-key
NEXT_PUBLIC_GOOGLE_PLACES_KEY=your-google-places-client-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-client-key

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# SMS Notifications (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
FEEDBACK_SMS_NUMBER=

# External Event APIs (optional - cold-start discovery)
EVENTBRITE_API_KEY=your-eventbrite-api-key
